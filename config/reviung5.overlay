#include <dt-bindings/gpio/gpio.h>

/ {
    chosen {
        zmk,keymap-sensors = &sensors;
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder>;
        triggers-per-rotation = <20>;
    };

    encoder: encoder {
        compatible = "alps,ec11";
        a-gpios = <&gpio1 15 GPIO_ACTIVE_HIGH>;
        b-gpios = <&gpio0 2 GPIO_ACTIVE_HIGH>;
        steps = <20>;
        status = "okay";
    };
};